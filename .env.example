# Copy to .env and fill in. Never commit .env (see .gitignore).
# All langley_risk settings are read with the LANGLEY_RISK_ prefix.

# --- OpenAI (required for the live agent / live evals) ---
OPENAI_API_KEY=sk-...

# --- Risk Guardian model ---
LANGLEY_RISK_MODEL=gpt-4o
LANGLEY_RISK_TEMPERATURE=0.0
LANGLEY_RISK_MAX_TURNS=8

# --- Data provider ---
# dexscreener (free, market only) | helius | composite (DexScreener + Helius contract data)
LANGLEY_RISK_PROVIDER=dexscreener
LANGLEY_RISK_DEXSCREENER_BASE_URL=https://api.dexscreener.com
LANGLEY_RISK_HTTP_TIMEOUT_SECONDS=10.0

# --- Helius contract enrichment (only when provider=helius|composite) ---
LANGLEY_RISK_HELIUS_API_KEY=
LANGLEY_RISK_HELIUS_RPC_URL=https://mainnet.helius-rpc.com

# --- Logging ---
LANGLEY_RISK_LOG_LEVEL=INFO
LANGLEY_RISK_LOG_JSON=false

# --- Evals ---
# Set to 1 to allow live (network + OpenAI) evals and integration tests.
LANGLEY_RISK_LIVE=0
